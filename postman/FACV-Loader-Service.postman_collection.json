{
  "info": {
    "_postman_id": "1f2a2ab4-84f8-4ba6-905e-8c6492f6897e",
    "name": "FACV Loader Service API",
    "description": "Postman collection for FACV loader manual APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health - GET /api/facv/health",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "pm.test('Response has status/service/timestamp', function () {",
              "    pm.expect(json).to.have.property('status');",
              "    pm.expect(json).to.have.property('service');",
              "    pm.expect(json).to.have.property('timestamp');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/facv/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "facv",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Manual Load - POST /api/facv/load",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "pm.test('Response has status/insertedRows/timestamp', function () {",
              "    pm.expect(json).to.have.property('status');",
              "    pm.expect(json).to.have.property('insertedRows');",
              "    pm.expect(json).to.have.property('timestamp');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/facv/load",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "facv",
            "load"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
